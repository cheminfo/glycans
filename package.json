{
  "name": "glycans",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Deals with glycans and their mass fragmentation",
  "keywords": [],
  "author": "Luc Patiny",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "benchmark": "tsx --watch benchmark/script.ts",
    "build": "npm run tsc && cheminfo-build --entry lib/index.js --root Glycans",
    "check-types": "tsc --noEmit",
    "clean": "rimraf coverage lib",
    "eslint": "eslint src benchmark benchmarkMultiCandidates",
    "eslint-fix": "eslint src benchmark benchmarkMultiCandidates --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src benchmark benchmarkMultiCandidates",
    "prettier-write": "prettier --write src benchmark benchmarkMultiCandidates",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "mass-fragmentation": "^1.12.1",
    "ml-spectra-processing": "^14.28.1",
    "openchemlib-utils": "^8.15.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "cheminfo-build": "^1.3.2",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@zakodium/tsconfig": "^1.0.5",
    "eslint": "^9.39.2",
    "eslint-config-cheminfo-typescript": "^22.0.0",
    "jcampconverter": "^12.3.1",
    "jsdom": "^29.1.1",
    "ms-spectrum": "^3.10.1",
    "openchemlib": "^9.22.1",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.3",
    "puppeteer": "^24.42.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/glycans.git"
  },
  "bugs": {
    "url": "https://github.com/cheminfo/glycans/issues"
  },
  "homepage": "https://github.com/cheminfo/glycans#readme"
}
